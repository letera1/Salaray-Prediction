   "name": "python",
   "version": "3.8.0"
  }
 },
 "nbformat": 4,
 "nbformat_minor": 4
}
,
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 3: Exploratory Data Analysis (EDA)\n",
    "\n",
    "Before building models, we need to understand our data:\n",
    "- Check for missing values\n",
    "- Understand data types\n",
    "- Examine statistical summaries\n",
    "- Visualize relationships between features and target"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Dataset information\n",
    "print(\"=\" * 60)\n",
    "print(\"DATASET INFORMATION\")\n",
    "print(\"=\" * 60)\n",
    "print(df.info())\n",
    "\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"MISSING VALUES\")\n",
    "print(\"=\" * 60)\n",
    "print(df.isnull().sum())\n",
    "\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"STATISTICAL SUMMARY\")\n",
    "print(\"=\" * 60)\n",
    "print(df.describe())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize relationships\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Experience vs Salary\n",
    "axes[0].scatter(df['experience'], df['salary'], alpha=0.6, color='blue')\n",
    "axes[0].set_xlabel('Experience (years)', fontsize=12)\n",
    "axes[0].set_ylabel('Salary ($)', fontsize=12)\n",
    "axes[0].set_title('Experience vs Salary', fontsize=14, fontweight='bold')\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "# Test Score vs Salary\n",
    "axes[1].scatter(df['test_score'], df['salary'], alpha=0.6, color='green')\n",
    "axes[1].set_xlabel('Test Score', fontsize=12)\n",
    "axes[1].set_ylabel('Salary ($)', fontsize=12)\n",
    "axes[1].set_title('Test Score vs Salary', fontsize=14, fontweight='bold')\n",
    "axes[1].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Correlation matrix\n",
    "print(\"\\nCorrelation with Salary:\")\n",
    "print(df[['experience', 'test_score', 'salary']].corr()['salary'].sort_values(ascending=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 4: Data Preprocessing\n",
    "\n",
    "### Preprocessing Steps:\n",
    "1. **Handle missing values**: Fill with median for numeric features\n",
    "2. **Encode categorical features**: Use OneHotEncoder for department and education level\n",
    "3. **Feature scaling**: Standardize numeric features for better model performance\n",
    "\n",
    "We'll create separate datasets for:\n",
    "- Single-feature model (experience only)\n",
    "- Multi-feature model (all features)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Handle missing values\n",
    "print(\"Handling missing values...\")\n",
    "df['test_score'].fillna(df['test_score'].median(), inplace=True)\n",
    "\n",
    "print(f\"✓ Missing values handled\")\n",
    "print(f\"\\nRemaining missing values: {df.isnull().sum().sum()}\")\n",
    "\n",
    "# Verify no missing values remain\n",
    "assert df.isnull().sum().sum() == 0, \"Missing values still present!\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Separate features and target\n",
    "X_single = df[['experience']]  # Single feature\n",
    "X_multi = df[['experience', 'test_score', 'department', 'education_level']]  # Multiple features\n",
    "y = df['salary']  # Target variable\n",
    "\n",
    "print(f\"Single-feature dataset shape: {X_single.shape}\")\n",
    "print(f\"Multi-feature dataset shape: {X_multi.shape}\")\n",
    "print(f\"Target variable shape: {y.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 5: Train-Test Split\n",
    "\n",
    "We split the data into:\n",
    "- **Training set (80%)**: Used to train the model\n",
    "- **Testing set (20%)**: Used to evaluate model performance on unseen data\n",
    "\n",
    "Using `random_state=42` ensures reproducibility."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Split for single-feature model\n",
    "X_single_train, X_single_test, y_single_train, y_single_test = train_test_split(\n",
    "    X_single, y, test_size=0.2, random_state=42\n",
    ")\n",
    "\n",
    "# Split for multi-feature model\n",
    "X_multi_train, X_multi_test, y_multi_train, y_multi_test = train_test_split(\n",
    "    X_multi, y, test_size=0.2, random_state=42\n",
    ")\n",
    "\n",
    "print(\"Train-Test Split Complete\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"Single-feature training samples: {X_single_train.shape[0]}\")\n",
    "print(f\"Single-feature testing samples: {X_single_test.shape[0]}\")\n",
    "print(f\"\\nMulti-feature training samples: {X_multi_train.shape[0]}\")\n",
    "print(f\"Multi-feature testing samples: {X_multi_test.shape[0]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 6: Model Training\n",
    "\n",
    "### Model 1: Simple Linear Regression (Single Feature)\n",
    "Uses only **experience** to predict salary.\n",
    "\n",
    "**Equation**: `salary = β₀ + β₁ × experience`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Train simple linear regression model\n",
    "print(\"Training Simple Linear Regression Model...\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "model_single = LinearRegression()\n",
    "model_single.fit(X_single_train, y_single_train)\n",
    "\n",
    "print(\"✓ Model trained successfully\")\n",
    "print(f\"\\nModel Coefficients:\")\n",
    "print(f\"  Intercept (β₀): ${model_single.intercept_:,.2f}\")\n",
    "print(f\"  Experience coefficient (β₁): ${model_single.coef_[0]:,.2f} per year\")\n",
    "print(f\"\\nInterpretation: Each additional year of experience increases salary by ${model_single.coef_[0]:,.2f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Model 2: Multiple Linear Regression (Multiple Features)\n",
    "Uses **experience, test_score, department, and education_level** to predict salary.\n",
    "\n",
    "We'll use a pipeline that:\n",
    "1. Encodes categorical features (OneHotEncoder)\n",
    "2. Scales numeric features (StandardScaler)\n",
    "3. Trains the linear regression model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define preprocessing for numeric and categorical features\n",
    "numeric_features = ['experience', 'test_score']\n",
    "categorical_features = ['department', 'education_level']\n",
    "\n",
    "# Create preprocessing pipelines\n",
    "numeric_transformer = StandardScaler()\n",
    "categorical_transformer = OneHotEncoder(drop='first', sparse_output=False)\n",
    "\n",
    "# Combine preprocessing steps\n",
    "preprocessor = ColumnTransformer(\n",
    "    transformers=[\n",
    "        ('num', numeric_transformer, numeric_features),\n",
    "        ('cat', categorical_transformer, categorical_features)\n",
    "    ]\n",
    ")\n",
    "\n",
    "# Create pipeline with preprocessing and model\n",
    "model_multi = Pipeline(steps=[\n",
    "    ('preprocessor', preprocessor),\n",
    "    ('regressor', LinearRegression())\n",
    "])\n",
    "\n",
    "print(\"Training Multiple Linear Regression Model...\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "model_multi.fit(X_multi_train, y_multi_train)\n",
    "\n",
    "print(\"✓ Model trained successfully\")\n",
    "print(f\"\\nModel uses {len(numeric_features)} numeric features and {len(categorical_features)} categorical features\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 7: Model Evaluation\n",
    "\n",
    "We'll evaluate both models using:\n",
    "- **RMSE (Root Mean Squared Error)**: Average prediction error in dollars (lower is better)\n",
    "- **R² Score**: Proportion of variance explained by the model (higher is better, max = 1.0)\n",
    "\n",
    "### Evaluation Metrics Interpretation:\n",
    "- **RMSE**: If RMSE = $5,000, predictions are off by ~$5,000 on average\n",
    "- **R²**: If R² = 0.85, the model explains 85% of salary variance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Make predictions\n",
    "y_single_pred = model_single.predict(X_single_test)\n",
    "y_multi_pred = model_multi.predict(X_multi_test)\n",
    "\n",
    "# Calculate metrics for single-feature model\n",
    "rmse_single = np.sqrt(mean_squared_error(y_single_test, y_single_pred))\n",
    "r2_single = r2_score(y_single_test, y_single_pred)\n",
    "\n",
    "# Calculate metrics for multi-feature model\n",
    "rmse_multi = np.sqrt(mean_squared_error(y_multi_test, y_multi_pred))\n",
    "r2_multi = r2_score(y_multi_test, y_multi_pred)\n",
    "\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"MODEL EVALUATION RESULTS\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "print(\"\\n📊 Simple Linear Regression (Experience Only):\")\n",
    "print(f\"  RMSE: ${rmse_single:,.2f}\")\n",
    "print(f\"  R² Score: {r2_single:.4f} ({r2_single*100:.2f}% variance explained)\")\n",
    "\n",
    "print(\"\\n📊 Multiple Linear Regression (All Features):\")\n",
    "print(f\"  RMSE: ${rmse_multi:,.2f}\")\n",
    "print(f\"  R² Score: {r2_multi:.4f} ({r2_multi*100:.2f}% variance explained)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 8: Model Comparison\n",
    "\n",
    "Let's compare both models side-by-side and determine which performs better."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create comparison DataFrame\n",
    "comparison_df = pd.DataFrame({\n",
    "    'Model': ['Simple Linear Regression', 'Multiple Linear Regression'],\n",
    "    'Features': ['Experience only', 'Experience + Test Score + Department + Education'],\n",
    "    'RMSE ($)': [rmse_single, rmse_multi],\n",
    "    'R² Score': [r2_single, r2_multi]\n",
    "})\n",
    "\n",
    "print(\"\\n\" + \"=\" * 80)\n",
    "print(\"MODEL COMPARISON\")\n",
    "print(\"=\" * 80)\n",
    "print(comparison_df.to_string(index=False))\n",
    "\n",
    "# Calculate improvement\n",
    "rmse_improvement = ((rmse_single - rmse_multi) / rmse_single) * 100\n",
    "r2_improvement = ((r2_multi - r2_single) / r2_single) * 100\n",
    "\n",
    "print(\"\\n\" + \"=\" * 80)\n",
    "print(\"PERFORMANCE IMPROVEMENT\")\n",
    "print(\"=\" * 80)\n",
    "print(f\"RMSE Reduction: {rmse_improvement:.2f}% (lower is better)\")\n",
    "print(f\"R² Improvement: {r2_improvement:.2f}% (higher is better)\")\n",
    "\n",
    "# Determine best model\n",
    "if r2_multi > r2_single:\n",
    "    best_model = \"Multiple Linear Regression\"\n",
    "    best_model_obj = model_multi\n",
    "    print(f\"\\n🏆 WINNER: {best_model}\")\n",
    "    print(f\"\\nThe multi-feature model outperforms the single-feature model by:\")\n",
    "    print(f\"  • Reducing prediction error by ${rmse_single - rmse_multi:,.2f}\")\n",
    "    print(f\"  • Explaining {(r2_multi - r2_single)*100:.2f}% more variance in salary\")\n",
    "else:\n",
    "    best_model = \"Simple Linear Regression\"\n",
    "    best_model_obj = model_single\n",
    "    print(f\"\\n🏆 WINNER: {best_model}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 9: Visualize Predictions\n",
    "\n",
    "Let's visualize how well our models predict salaries compared to actual values."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create visualization\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 5))\n",
    "\n",
    "# Simple Linear Regression predictions\n",
    "axes[0].scatter(y_single_test, y_single_pred, alpha=0.6, color='blue')\n",
    "axes[0].plot([y_single_test.min(), y_single_test.max()], \n",
    "             [y_single_test.min(), y_single_test.max()], \n",
    "             'r--', lw=2, label='Perfect Prediction')\n",
    "axes[0].set_xlabel('Actual Salary ($)', fontsize=12)\n",
    "axes[0].set_ylabel('Predicted Salary ($)', fontsize=12)\n",
    "axes[0].set_title(f'Simple Linear Regression\\nR² = {r2_single:.4f}', fontsize=14, fontweight='bold')\n",
    "axes[0].legend()\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "# Multiple Linear Regression predictions\n",
    "axes[1].scatter(y_multi_test, y_multi_pred, alpha=0.6, color='green')\n",
    "axes[1].plot([y_multi_test.min(), y_multi_test.max()], \n",
    "             [y_multi_test.min(), y_multi_test.max()], \n",
    "             'r--', lw=2, label='Perfect Prediction')\n",
    "axes[1].set_xlabel('Actual Salary ($)', fontsize=12)\n",
    "axes[1].set_ylabel('Predicted Salary ($)', fontsize=12)\n",
    "axes[1].set_title(f'Multiple Linear Regression\\nR² = {r2_multi:.4f}', fontsize=14, fontweight='bold')\n",
    "axes[1].legend()\n",
    "axes[1].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nNote: Points closer to the red dashed line indicate better predictions\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 10: Save the Best Model\n",
    "\n",
    "We'll save the best performing model using `joblib` for future use in production.\n",
    "\n",
    "The saved model can be loaded later using: `model = joblib.load('best_salary_model.pkl')`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save the best model\n",
    "model_filename = 'best_salary_model.pkl'\n",
    "joblib.dump(best_model_obj, model_filename)\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"MODEL SAVED SUCCESSFULLY\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"Model: {best_model}\")\n",
    "print(f\"Filename: {model_filename}\")\n",
    "print(f\"File size: {os.path.getsize(model_filename) / 1024:.2f} KB\")\n",
    "\n",
    "# Verify model can be loaded\n",
    "loaded_model = joblib.load(model_filename)\n",
    "print(f\"\\n✓ Model verification: Successfully loaded from disk\")\n",
    "\n",
    "# Test loaded model\n",
    "if best_model == \"Multiple Linear Regression\":\n",
    "    test_prediction = loaded_model.predict(X_multi_test[:1])\n",
    "else:\n",
    "    test_prediction = loaded_model.predict(X_single_test[:1])\n",
    "    \n",
    "print(f\"✓ Model test: Successfully made prediction: ${test_prediction[0]:,.2f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 11: Make Predictions with New Data\n",
    "\n",
    "Here's how to use the saved model to predict salaries for new employees."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Example: Predict salary for new employees\n",
    "print(\"=\" * 60)\n",
    "print(\"PREDICTION EXAMPLES\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "if best_model == \"Multiple Linear Regression\":\n",
    "    # Create sample data for prediction\n",
    "    new_employees = pd.DataFrame({\n",
    "        'experience': [3, 7, 12],\n",
    "        'test_score': [75, 85, 95],\n",
    "        'department': ['Engineering', 'Sales', 'Marketing'],\n",
    "        'education_level': ['Bachelor', 'Master', 'PhD']\n",
    "    })\n",
    "    \n",
    "    predictions = loaded_model.predict(new_employees)\n",
    "    \n",
    "    new_employees['predicted_salary'] = predictions\n",
    "    print(\"\\nNew Employee Salary Predictions:\")\n",
    "    print(new_employees.to_string(index=False))\n",
    "    \n",
    "else:\n",
    "    # Simple model only uses experience\n",
    "    new_employees = pd.DataFrame({\n",
    "        'experience': [3, 7, 12]\n",
    "    })\n",
    "    \n",
    "    predictions = loaded_model.predict(new_employees)\n",
    "    \n",
    "    new_employees['predicted_salary'] = predictions\n",
    "    print(\"\\nNew Employee Salary Predictions:\")\n",
    "    print(new_employees.to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Summary and Key Takeaways\n",
    "\n",
    "### What We Accomplished:\n",
