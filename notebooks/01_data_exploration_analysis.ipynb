  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📥 Data Loading and Initial Inspection\n",
    "\n",
    "Let's load our Ethiopian tech salary dataset and perform initial quality checks."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load the Ethiopian salary dataset\n",
    "print(\"🇪🇹 Loading Ethiopian Tech Salary Dataset\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "try:\n",
    "    df = pd.read_csv('../ethiopia_salary_data.csv')\n",
    "    print(f\"✅ Dataset loaded successfully!\")\n",
    "    print(f\"📊 Shape: {df.shape[0]:,} rows × {df.shape[1]} columns\")\n",
    "except FileNotFoundError:\n",
    "    print(\"❌ Dataset file not found. Please check the file path.\")\n",
    "    raise\n",
    "\n",
    "# Display basic information\n",
    "print(\"\\n📋 Dataset Info:\")\n",
    "print(\"-\" * 30)\n",
    "df.info()\n",
    "\n",
    "print(\"\\n🔍 First 5 rows:\")\n",
    "print(\"-\" * 30)\n",
    "display(df.head())\n",
    "\n",
    "print(\"\\n📈 Statistical Summary:\")\n",
    "print(\"-\" * 30)\n",
    "display(df.describe())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Data quality assessment\n",
    "print(\"🔍 DATA QUALITY ASSESSMENT\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# Missing values analysis\n",
    "missing_data = df.isnull().sum()\n",
    "missing_percent = (missing_data / len(df)) * 100\n",
    "\n",
    "missing_df = pd.DataFrame({\n",
    "    'Column': missing_data.index,\n",
    "    'Missing Count': missing_data.values,\n",
    "    'Missing Percentage': missing_percent.values\n",
    "})\n",
    "\n",
    "missing_df = missing_df[missing_df['Missing Count'] > 0].sort_values('Missing Count', ascending=False)\n",
    "\n",
    "if len(missing_df) > 0:\n",
    "    print(\"⚠️  Missing Values Found:\")\n",
    "    display(missing_df)\n",
    "else:\n",
    "    print(\"✅ No missing values found!\")\n",
    "\n",
    "# Duplicate analysis\n",
    "duplicates = df.duplicated().sum()\n",
    "print(f\"\\n🔄 Duplicate rows: {duplicates}\")\n",
    "\n",
    "# Data types analysis\n",
    "print(\"\\n📊 Data Types:\")\n",
    "print(\"-\" * 20)\n",
    "for col in df.columns:\n",
    "    dtype = df[col].dtype\n",
    "    unique_count = df[col].nunique()\n",
    "    print(f\"{col:20} | {str(dtype):10} | {unique_count:3} unique values\")\n",
    "\n",
    "# Outlier detection for numerical columns\n",
    "print(\"\\n🎯 Outlier Detection (IQR Method):\")\n",
    "print(\"-\" * 40)\n",
    "numerical_cols = df.select_dtypes(include=[np.number]).columns\n",
    "\n",
    "for col in numerical_cols:\n",
    "    Q1 = df[col].quantile(0.25)\n",
    "    Q3 = df[col].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    lower_bound = Q1 - 1.5 * IQR\n",
    "    upper_bound = Q3 + 1.5 * IQR\n",
    "    \n",
    "    outliers = df[(df[col] < lower_bound) | (df[col] > upper_bound)]\n",
    "    outlier_count = len(outliers)\n",
    "    outlier_percent = (outlier_count / len(df)) * 100\n",
    "    \n",
    "    print(f\"{col:20} | {outlier_count:3} outliers ({outlier_percent:.1f}%)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🎨 Advanced Data Visualization\n",
    "\n",
    "Let's create comprehensive visualizations to understand our data better."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create comprehensive salary distribution analysis\n",
    "print(\"💰 SALARY DISTRIBUTION ANALYSIS\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# Convert ETB to USD for international context\n",
    "df['salary_usd'] = df['salary_etb'] / 55  # 1 USD ≈ 55 ETB\n",
    "\n",
    "# Create subplots for salary analysis\n",
    "fig, axes = plt.subplots(2, 3, figsize=(20, 12))\n",
    "fig.suptitle('Ethiopian Tech Salary Distribution Analysis', fontsize=16, fontweight='bold')\n",
    "\n",
    "# 1. Salary distribution histogram\n",
    "axes[0, 0].hist(df['salary_etb'], bins=30, alpha=0.7, color='skyblue', edgecolor='black')\n",
    "axes[0, 0].set_title('Salary Distribution (ETB)', fontweight='bold')\n",
    "axes[0, 0].set_xlabel('Salary (ETB)')\n",
    "axes[0, 0].set_ylabel('Frequency')\n",
    "axes[0, 0].ticklabel_format(style='plain', axis='x')\n",
    "\n",
    "# 2. Log-transformed salary distribution\n",
    "axes[0, 1].hist(np.log(df['salary_etb']), bins=30, alpha=0.7, color='lightgreen', edgecolor='black')\n",
    "axes[0, 1].set_title('Log-Transformed Salary Distribution', fontweight='bold')\n",
    "axes[0, 1].set_xlabel('Log(Salary ETB)')\n",
    "axes[0, 1].set_ylabel('Frequency')\n",
    "\n",
    "# 3. Salary by department boxplot\n",
    "df.boxplot(column='salary_etb', by='department', ax=axes[0, 2])\n",
    "axes[0, 2].set_title('Salary Distribution by Department', fontweight='bold')\n",
    "axes[0, 2].set_xlabel('Department')\n",
    "axes[0, 2].set_ylabel('Salary (ETB)')\n",
    "axes[0, 2].tick_params(axis='x', rotation=45)\n",
    "\n",
    "# 4. Salary by education level\n",
    "df.boxplot(column='salary_etb', by='education_level', ax=axes[1, 0])\n",
    "axes[1, 0].set_title('Salary Distribution by Education Level', fontweight='bold')\n",
    "axes[1, 0].set_xlabel('Education Level')\n",
    "axes[1, 0].set_ylabel('Salary (ETB)')\n",
    "\n",
    "# 5. Experience vs Salary scatter plot\n",
    "axes[1, 1].scatter(df['experience_years'], df['salary_etb'], alpha=0.6, color='coral')\n",
    "axes[1, 1].set_title('Experience vs Salary Relationship', fontweight='bold')\n",
    "axes[1, 1].set_xlabel('Years of Experience')\n",
    "axes[1, 1].set_ylabel('Salary (ETB)')\n",
    "\n",
    "# Add trend line\n",
    "z = np.polyfit(df['experience_years'], df['salary_etb'], 1)\n",
    "p = np.poly1d(z)\n",
    "axes[1, 1].plot(df['experience_years'], p(df['experience_years']), \"r--\", alpha=0.8)\n",
    "\n",
    "# 6. Test score vs Salary (handling missing values)\n",
    "df_clean = df.dropna(subset=['test_score'])\n",
    "axes[1, 2].scatter(df_clean['test_score'], df_clean['salary_etb'], alpha=0.6, color='purple')\n",
    "axes[1, 2].set_title('Test Score vs Salary Relationship', fontweight='bold')\n",
    "axes[1, 2].set_xlabel('Test Score')\n",
    "axes[1, 2].set_ylabel('Salary (ETB)')\n",
    "\n",
    "# Add trend line\n",
    "z2 = np.polyfit(df_clean['test_score'], df_clean['salary_etb'], 1)\n",
    "p2 = np.poly1d(z2)\n",
    "axes[1, 2].plot(df_clean['test_score'], p2(df_clean['test_score']), \"r--\", alpha=0.8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Print summary statistics\n",
    "print(\"\\n📊 Salary Statistics (ETB):\")\n",
    "print(\"-\" * 30)\n",
    "salary_stats = df['salary_etb'].describe()\n",
    "for stat, value in salary_stats.items():\n",
    "    print(f\"{stat.capitalize():10}: {value:,.0f} ETB\")\n",
    "\n",
    "print(\"\\n💵 Salary Statistics (USD):\")\n",
    "print(\"-\" * 30)\n",
    "salary_usd_stats = df['salary_usd'].describe()\n",
    "for stat, value in salary_usd_stats.items():\n",
    "    print(f\"{stat.capitalize():10}: ${value:,.0f} USD\")"
   ]
  }
